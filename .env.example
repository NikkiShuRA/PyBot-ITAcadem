# Пример файла .env для локальной разработки / документации
# Не храните реальные секреты в этом файле в публичном репозитории.
# Используйте настоящие значения в локальном `.env` (он игнорируется через .gitignore)

# Telegram tokens
# BOT_TOKEN — production токен (если используете)
BOT_TOKEN=your_production_bot_token_here

# BOT_TOKEN_TEST — тестовый токен (используется при BOT_MODE=test)
BOT_TOKEN_TEST=your_test_bot_token_here
BOT_MODE=test
NOTIFICATION_BACKEND=telegram
# Allowed values: telegram | logging
TELEGRAM_PROXY_URL=
# Optional proxy URL for Telegram API traffic used by polling and worker notifications
FSM_STORAGE_BACKEND=memory
# Allowed values: memory | redis
REDIS_URL=redis://localhost:6379/0

# Telegram user id of admin recipient for role request notifications
ROLE_REQUEST_ADMIN_TG_ID=123456789
# Telegram ids that should automatically receive Admin role on registration
# Format: JSON array of integers (pydantic-settings parses it automatically)
AUTO_ADMIN_TELEGRAM_IDS=[123456789,987654321]

# SQLite connection
# Local: sqlite+aiosqlite:///./your_name.db
# Docker: sqlite+aiosqlite:///./data/pybot_itacadem.db
DATABASE_URL=sqlite+aiosqlite:///./your_name.db
AUTO_SEED_DB=false

# Logging and Debugging
DEBUG=True
LOG_LEVEL=INFO

# Rate-limiting
ENABLE_RATE_LIMIT=True

RATE_LIMIT_CHEAP=30
TIME_LIMIT_CHEAP=60

RATE_LIMIT_MODERATE=10
TIME_LIMIT_MODERATE=60

RATE_LIMIT_EXPENSIVE=3
TIME_LIMIT_EXPENSIVE=300

MAX_USER_LIMITERS=1000

# Broadcast safety settings
# Keep values in safe ranges to avoid Telegram anti-spam limits.
BROADCAST_BULK_SIZE=20
BROADCAST_MAX_CONCURRENCY=5
BROADCAST_BATCH_PAUSE_MS=1200
BROADCAST_JITTER_MIN_MS=80
BROADCAST_JITTER_MAX_MS=160
BROADCAST_RETRY_ATTEMPTS=5
BROADCAST_RETRY_MAX_WAIT_S=30

BROADCAST_ALLOWED_ROLES=Admin
# Broadcast body length before crop suffix ("..."), recommended 4093 for Telegram.
BROADCAST_MAX_TEXT_LENGTH=4093

ENABLE_LOGGING_MIDDLEWARE=True
ENABLE_USER_ACTIVITY_MIDDLEWARE=True
ENABLE_ROLE_MIDDLEWARE=True

# Health API (FastAPI)
HEALTH_API_ENABLED=False
HEALTH_API_HOST=0.0.0.0
HEALTH_API_PORT=8001
